<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - CodeNotes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'admin-bg': '#0f172a',
              'admin-card': '#1e293b',
              'admin-border': '#334155',
              'admin-accent': '#3b82f6',
              'admin-text': '#f1f5f9',
              'admin-text-dim': '#94a3b8',
            }
          }
        }
      }
    </script>
</head>
<body class="bg-admin-bg text-admin-text min-h-screen">
    <!-- Header -->
    <header class="bg-admin-card border-b border-admin-border px-6 py-4">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold text-admin-text flex items-center">
                <i class="fas fa-shield-alt text-admin-accent mr-3"></i>
                Admin Dashboard
            </h1>
            <div class="flex items-center space-x-4">
                <span class="text-admin-text-dim">Welcome, <%= username %></span>
                <a href="/dashboard" class="bg-admin-accent hover:bg-blue-600 text-white px-4 py-2 rounded-lg">
                    <i class="fas fa-home mr-2"></i>Back to App
                </a>
                <a href="/logout" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg">
                    <i class="fas fa-sign-out-alt mr-2"></i>Logout
                </a>
            </div>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="bg-admin-card border-b border-admin-border px-6 py-3">
        <div class="flex space-x-6">
            <a href="/admin" class="text-admin-accent border-b-2 border-admin-accent pb-2">
                <i class="fas fa-chart-bar mr-2"></i>Dashboard
            </a>
            <a href="/admin/users" class="text-admin-text-dim hover:text-admin-text">
                <i class="fas fa-users mr-2"></i>Users
            </a>
            <a href="/admin/documents" class="text-admin-text-dim hover:text-admin-text">
                <i class="fas fa-file-alt mr-2"></i>Documents
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="p-6">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-admin-text-dim text-sm">Total Users</p>
                        <p class="text-2xl font-bold text-admin-text"><%= stats.totalUsers %></p>
                    </div>
                    <i class="fas fa-users text-3xl text-blue-500"></i>
                </div>
            </div>
            
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-admin-text-dim text-sm">Total Documents</p>
                        <p class="text-2xl font-bold text-admin-text"><%= stats.totalDocuments %></p>
                    </div>
                    <i class="fas fa-file-alt text-3xl text-green-500"></i>
                </div>
            </div>
            
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-admin-text-dim text-sm">Public Documents</p>
                        <p class="text-2xl font-bold text-admin-text"><%= stats.publicDocuments %></p>
                    </div>
                    <i class="fas fa-globe text-3xl text-yellow-500"></i>
                </div>
            </div>
            
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-admin-text-dim text-sm">Private Documents</p>
                        <p class="text-2xl font-bold text-admin-text"><%= stats.privateDocuments %></p>
                    </div>
                    <i class="fas fa-lock text-3xl text-red-500"></i>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Recent Users -->
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <h2 class="text-xl font-semibold text-admin-text mb-4 flex items-center">
                    <i class="fas fa-user-plus text-admin-accent mr-2"></i>
                    Recent Users
                </h2>
                <div class="space-y-3">
                    <% recentUsers.forEach(user => { %>
                    <div class="flex items-center justify-between py-2 border-b border-admin-border">
                        <div>
                            <p class="font-medium text-admin-text"><%= user.name %></p>
                            <p class="text-sm text-admin-text-dim"><%= user.email %></p>
                        </div>
                        <span class="text-xs text-admin-text-dim">
                            <%= new Date(user.createdAt).toLocaleDateString() %>
                        </span>
                    </div>
                    <% }); %>
                </div>
                <a href="/admin/users" class="text-admin-accent hover:underline text-sm mt-4 block">
                    View all users →
                </a>
            </div>

            <!-- Recent Documents -->
            <div class="bg-admin-card border border-admin-border rounded-lg p-6">
                <h2 class="text-xl font-semibold text-admin-text mb-4 flex items-center">
                    <i class="fas fa-file-plus text-admin-accent mr-2"></i>
                    Recent Documents
                </h2>
                <div class="space-y-3">
                    <% recentDocuments.forEach(doc => { %>
                    <div class="flex items-center justify-between py-2 border-b border-admin-border">
                        <div>
                            <p class="font-medium text-admin-text"><%= doc.title %></p>
                            <p class="text-sm text-admin-text-dim">by <%= doc.user.name %></p>
                        </div>
                        <div class="text-right">
                            <span class="text-xs <%= doc.isPublic ? 'text-green-400' : 'text-red-400' %>">
                                <%= doc.isPublic ? 'Public' : 'Private' %>
                            </span>
                            <p class="text-xs text-admin-text-dim">
                                <%= new Date(doc.Currentdate).toLocaleDateString() %>
                            </p>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <a href="/admin/documents" class="text-admin-accent hover:underline text-sm mt-4 block">
                    View all documents →
                </a>
            </div>
        </div>
    </main>

    <!-- Flash Messages -->
    <script>
      window.flashMessages = {
        success: '<%= typeof success !== "undefined" ? success : "" %>',
        error: '<%= typeof error !== "undefined" ? error : "" %>',
        warning: '<%= typeof warning !== "undefined" ? warning : "" %>'
      };
    </script>

    <script>
      if (window.flashMessages.success) {
        Toastify({
          text: window.flashMessages.success,
          duration: 3000,
          style: { background: "linear-gradient(to right, #00b09b, #96c93d)" }
        }).showToast();
      }
      
      if (window.flashMessages.error) {
        Toastify({
          text: window.flashMessages.error,
          duration: 3000,
          style: { background: "linear-gradient(to right, #ff5f6d, #ffc371)" }
        }).showToast();
      }
    </script>
</body>
</html>
