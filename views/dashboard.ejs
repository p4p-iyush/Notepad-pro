<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — ThoughtVault</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="bg-gray-950 text-white min-h-screen">

  <%- include('partials/navbar') %>

  <div class="max-w-6xl mx-auto px-4 py-8">

    <!-- Flash -->
    <% if (success && success.length > 0) { %>
      <div class="bg-green-500/20 border border-green-500 text-green-400 px-4 py-2 rounded-lg mb-4 text-sm">
        <%= success[0] %>
      </div>
    <% } %>

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="text-2xl font-bold text-white">My Documents</h2>
        <p class="text-gray-500 text-sm mt-1"><%= documents.length %> documents</p>
      </div>
      <button onclick="openModal()"
        class="bg-violet-600 hover:bg-violet-700 text-white px-5 py-2.5 rounded-xl
               font-semibold transition flex items-center gap-2">
        <span class="text-lg">+</span> New Document
      </button>
    </div>

    <!-- Documents Grid -->
    <div id="docsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

      <% if (documents.length === 0) { %>
        <div class="col-span-3 text-center text-gray-600 py-20">
          <p class="text-5xl mb-4">🧠</p>
          <p class="text-lg">No documents yet. Create your first one!</p>
        </div>
      <% } %>

      <% documents.forEach(doc => { %>
        <div class="doc-card bg-gray-900 border border-gray-800 rounded-2xl p-5
                    hover:border-violet-500/50 transition duration-200 cursor-pointer flex flex-col gap-3"
             data-id="<%= doc._id %>"
             data-visibility="<%= doc.visibility %>"
             data-title="<%= doc.title.toLowerCase() %>"
             onclick="openDoc('<%= doc._id %>')">

          <!-- Card Top -->
          <div class="flex items-start justify-between">
            <h3 class="font-semibold text-white text-lg truncate max-w-[180px]">
              <%= doc.pinned ? '📌 ' : '' %><%= doc.title %>
            </h3>
            <span class="text-xs px-2 py-1 rounded-full font-medium shrink-0
              <%= doc.visibility === 'public'
                ? 'bg-green-500/20 text-green-400 border border-green-500/30'
                : 'bg-gray-700 text-gray-400 border border-gray-600' %>">
              <%= doc.visibility === 'public' ? '🌐 Public' : '🔒 Private' %>
            </span>
          </div>

          <!-- Block Count -->
          <div class="flex gap-3 text-xs text-gray-500">
            <span>📝 <%= doc.blocks.filter(b => b.type === 'text').length %> text</span>
            <span>💻 <%= doc.blocks.filter(b => b.type === 'code').length %> code</span>
            <span>✅ <%= doc.blocks.filter(b => b.type === 'todo').length %> todo</span>
          </div>

          <!-- Tags -->
          <% if (doc.tags && doc.tags.length > 0) { %>
            <div class="flex flex-wrap gap-1">
              <% doc.tags.forEach(tag => { %>
                <span class="text-xs bg-violet-500/20 text-violet-400 px-2 py-0.5 rounded-full">
                  #<%= tag %>
                </span>
              <% }) %>
            </div>
          <% } %>

          <!-- Card Footer -->
          <div class="flex items-center justify-between pt-2 border-t border-gray-800 mt-auto">
            <span class="text-xs text-gray-600">
              <%= new Date(doc.updatedAt).toLocaleDateString('en-US',
                { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </span>
            <div class="flex gap-3" onclick="event.stopPropagation()">
              <!-- Pin -->
              <button onclick="pinDoc('<%= doc._id %>', <%= doc.pinned ? 'true' : 'false' %>)"
                class="text-sm transition <%= doc.pinned ? 'text-yellow-400' : 'text-gray-600 hover:text-yellow-400' %>"
                title="Pin">📌
              </button>
              <!-- Delete -->
              <button onclick="deleteDoc('<%= doc._id %>')"
                class="text-sm text-gray-600 hover:text-red-400 transition"
                title="Delete">🗑️
              </button>
            </div>
          </div>

        </div>
      <% }) %>

    </div>
  </div>

  <!-- ═══ CREATE DOCUMENT MODAL ═══ -->
  <div id="modal"
    class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm z-50
           flex items-center justify-center p-4">
    <div class="bg-gray-900 border border-gray-700 rounded-2xl w-full max-w-md p-6">

      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xl font-bold text-white">New Document</h3>
        <button onclick="closeModal()"
          class="text-gray-500 hover:text-white text-2xl leading-none">×
        </button>
      </div>

      <!-- Title -->
      <div class="mb-4">
        <label class="block text-sm text-gray-400 mb-1">Title</label>
        <input id="docTitle" type="text" placeholder="My awesome notes..."
          class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5
                 text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition"/>
      </div>

      <!-- Visibility -->
      <div class="mb-4">
        <label class="block text-sm text-gray-400 mb-1">Visibility</label>
        <select id="docVisibility"
          class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5
                 text-white focus:outline-none focus:border-violet-500 transition">
          <option value="private">🔒 Private</option>
          <option value="public">🌐 Public</option>
        </select>
      </div>

      <!-- Tags -->
      <div class="mb-6">
        <label class="block text-sm text-gray-400 mb-1">
          Tags <span class="text-gray-600">(comma separated)</span>
        </label>
        <input id="docTags" type="text" placeholder="work, ideas, personal"
          class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2.5
                 text-white placeholder-gray-500 focus:outline-none focus:border-violet-500 transition"/>
      </div>

      <!-- Actions -->
      <div class="flex gap-3">
        <button onclick="createDoc()"
          class="flex-1 bg-violet-600 hover:bg-violet-700 text-white
                 font-semibold py-2.5 rounded-xl transition">
          Create & Open
        </button>
        <button onclick="closeModal()"
          class="px-5 bg-gray-800 hover:bg-gray-700 text-gray-300
                 font-semibold py-2.5 rounded-xl transition">
          Cancel
        </button>
      </div>

    </div>
  </div>

  <script src="/js/dashboard.js"></script>

</body>
</html>