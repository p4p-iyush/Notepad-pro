<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit - <%=text.title%> | CodeNotes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'editor-bg': '#0d1117',
              'editor-sidebar': '#161b22',
              'editor-card': '#21262d',
              'editor-border': '#30363d',
              'editor-accent': '#58a6ff',
              'editor-text': '#f0f6fc',
              'editor-text-dim': '#7d8590',
              'code-bg': '#161b22',
              'toolbar-bg': '#1c2128',
            }
          }
        }
      }
    </script>
    <!-- Add Toastify CSS & JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <style>
        .editor-content {
            min-height: 500px;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            line-height: 1.6;
        }
        
        .toolbar-button {
            transition: all 0.2s ease;
        }
        
        .toolbar-button:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(88, 166, 255, 0.3);
        }
        
        .toolbar-button.active {
            background-color: #58a6ff;
            color: white;
        }
        
        .code-block {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 6px;
            padding: 16px;
            margin: 10px 0;
            font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
            position: relative;
        }
        
        .code-block::before {
            content: attr(data-language);
            position: absolute;
            top: 8px;
            right: 12px;
            font-size: 12px;
            color: #7d8590;
            text-transform: uppercase;
        }
        
        .mode-indicator {
            position: absolute;
            top: 10px;
            right: 10px;
            padding: 4px 8px;
            background: rgba(88, 166, 255, 0.2);
            border-radius: 4px;
            font-size: 12px;
            color: #58a6ff;
        }

        .unsaved-changes {
            background: rgba(255, 193, 7, 0.2);
            color: #ffc107;
        }

        .save-success {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
        }
    </style>
</head>
<body class="bg-editor-bg text-editor-text font-mono min-h-screen">
    <!-- Header -->
    <header class="bg-editor-sidebar border-b border-editor-border px-6 py-4">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <a href="/dashboard" class="text-editor-text-dim hover:text-editor-text transition-colors duration-200 flex items-center space-x-2">
                    <i class="fas fa-arrow-left"></i>
                    <span>Back to Dashboard</span>
                </a>
                <div class="h-6 w-px bg-editor-border"></div>
                <h1 class="text-lg font-semibold text-editor-text flex items-center">
                    <i class="fas fa-edit text-editor-accent mr-2"></i>
                    Editing Document
                </h1>
            </div>
            <div class="flex items-center space-x-3">
                <div id="saveStatus" class="text-sm text-editor-text-dim flex items-center space-x-2">
                    <i class="fas fa-circle text-green-500 text-xs"></i>
                    <span>All changes saved</span>
                </div>
                <a href="/view/<%=text._id%>" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg transition-all duration-200 flex items-center space-x-2">
                    <i class="fas fa-eye"></i>
                    <span>Preview</span>
                </a>
            </div>
        </div>
    </header>

    <!-- Main Container -->
    <div class="flex flex-col h-screen">
        <!-- File Title Section -->
        <div class="bg-editor-card border-b border-editor-border px-6 py-4">
            <div class="flex items-center space-x-4">
                <div class="flex-1">
                    <label class="block text-sm font-medium text-editor-text mb-2">
                        <i class="fas fa-file-alt mr-2"></i>File Name
                    </label>
                    <div class="flex items-center space-x-2">
                        <input type="text" 
                               class="files_title_input flex-1 bg-editor-bg border border-editor-border rounded-lg px-4 py-2 text-editor-text placeholder-editor-text-dim focus:border-editor-accent focus:outline-none transition-colors duration-200" 
                               placeholder="Enter file name"
                               value="<%= text.title %>">
                        <span class="text-editor-text-dim">.txt</span>
                    </div>
                </div>
                <div class="flex items-center space-x-4">
                    <div class="flex items-center space-x-2">
                        <input type="checkbox" id="isPublic" <%=text.isPublic ? 'checked' : ''%> class="w-4 h-4 text-editor-accent bg-editor-bg border-editor-border rounded focus:ring-editor-accent">
                        <label for="isPublic" class="text-sm text-editor-text flex items-center">
                            <i class="fas fa-globe mr-1"></i>Make Public
                        </label>
                    </div>
                    <button onclick="saveContent()" 
                            class="bg-editor-accent hover:bg-blue-600 text-white px-6 py-2 rounded-lg font-medium transition-all duration-200 flex items-center space-x-2 shadow-lg hover:shadow-xl">
                        <i class="fas fa-save"></i>
                        <span>Update</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Editor Container -->
        <div class="flex-1 flex">
            <!-- Sidebar - Mode Switcher -->
            <div class="bg-editor-sidebar border-r border-editor-border w-16 flex flex-col items-center py-6 space-y-4">
                <button onclick="switchMode('text')" id="textModeBtn" 
                        class="mode-btn w-12 h-12 bg-editor-card hover:bg-editor-accent text-editor-text hover:text-white rounded-lg transition-all duration-200 flex items-center justify-center active"
                        title="Text Mode">
                    <i class="fas fa-font"></i>
                </button>
                <button onclick="switchMode('code')" id="codeModeBtn" 
                        class="mode-btn w-12 h-12 bg-editor-card hover:bg-editor-accent text-editor-text hover:text-white rounded-lg transition-all duration-200 flex items-center justify-center"
                        title="Code Mode">
                    <i class="fas fa-code"></i>
                </button>
                <div class="h-px w-8 bg-editor-border my-2"></div>
                <button onclick="insertCodeBlock()" 
                        class="w-12 h-12 bg-editor-card hover:bg-green-600 text-editor-text hover:text-white rounded-lg transition-all duration-200 flex items-center justify-center"
                        title="Insert Code Block">
                    <i class="fas fa-plus"></i>
                </button>
                <button onclick="showVersionHistory()" 
                        class="w-12 h-12 bg-editor-card hover:bg-purple-600 text-editor-text hover:text-white rounded-lg transition-all duration-200 flex items-center justify-center"
                        title="Version History">
                    <i class="fas fa-history"></i>
                </button>
            </div>

            <!-- Main Editor Area -->
            <div class="flex-1 flex flex-col">
                <!-- Toolbar -->
                <div id="textToolbar" class="toolbar bg-toolbar-bg border-b border-editor-border px-6 py-3">
                    <div class="flex items-center space-x-2 flex-wrap gap-2">
                        <!-- Formatting Buttons -->
                        <div class="flex items-center space-x-1 bg-editor-card rounded-lg p-1">
                            <button onclick="formatText('bold')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Bold (Ctrl+B)">
                                <i class="fas fa-bold"></i>
                            </button>
                            <button onclick="formatText('italic')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Italic (Ctrl+I)">
                                <i class="fas fa-italic"></i>
                            </button>
                            <button onclick="formatText('underline')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Underline (Ctrl+U)">
                                <i class="fas fa-underline"></i>
                            </button>
                        </div>

                        <div class="h-8 w-px bg-editor-border"></div>

                        <!-- Alignment -->
                        <div class="flex items-center space-x-1 bg-editor-card rounded-lg p-1">
                            <button onclick="formatText('justifyLeft')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Align Left">
                                <i class="fas fa-align-left"></i>
                            </button>
                            <button onclick="formatText('justifyCenter')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Center">
                                <i class="fas fa-align-center"></i>
                            </button>
                            <button onclick="formatText('justifyRight')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Align Right">
                                <i class="fas fa-align-right"></i>
                            </button>
                        </div>

                        <div class="h-8 w-px bg-editor-border"></div>

                        <!-- Lists -->
                        <div class="flex items-center space-x-1 bg-editor-card rounded-lg p-1">
                            <button onclick="insertList('insertUnorderedList')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Bullet List">
                                <i class="fas fa-list-ul"></i>
                            </button>
                            <button onclick="insertList('insertOrderedList')" class="toolbar-button px-3 py-2 rounded text-editor-text hover:bg-editor-accent hover:text-white transition-all duration-200" title="Numbered List">
                                <i class="fas fa-list-ol"></i>
                            </button>
                        </div>

                        <div class="h-8 w-px bg-editor-border"></div>

                        <!-- Font Controls -->
                        <select onchange="changeFont(this.value)" class="bg-editor-card border border-editor-border rounded px-3 py-2 text-editor-text text-sm focus:border-editor-accent focus:outline-none">
                            <option value="Arial">Arial</option>
                            <option value="Times New Roman">Times New Roman</option>
                            <option value="Courier New" selected>Courier New</option>
                            <option value="Verdana">Verdana</option>
                            <option value="Georgia">Georgia</option>
                        </select>

                        <select onchange="changeFontSize(this.value)" class="bg-editor-card border border-editor-border rounded px-3 py-2 text-editor-text text-sm focus:border-editor-accent focus:outline-none">
                            <option value="1">Small</option>
                            <option value="3" selected>Normal</option>
                            <option value="5">Large</option>
                            <option value="7">Extra Large</option>
                        </select>

                        <input type="color" onchange="changeTextColor(this.value)" 
                               class="w-10 h-8 border border-editor-border rounded cursor-pointer" 
                               title="Text Color">
                    </div>
                </div>

                <!-- Code Toolbar -->
                <div id="codeToolbar" class="toolbar bg-toolbar-bg border-b border-editor-border px-6 py-3 hidden">
                    <div class="flex items-center space-x-4">
                        <div class="flex items-center space-x-2">
                            <label class="text-sm text-editor-text">Language:</label>
                            <select id="codeLanguage" class="bg-editor-card border border-editor-border rounded px-3 py-2 text-editor-text text-sm focus:border-editor-accent focus:outline-none">
                                <option value="javascript">JavaScript</option>
                                <option value="python">Python</option>
                                <option value="html">HTML</option>
                                <option value="css">CSS</option>
                                <option value="java">Java</option>
                                <option value="cpp">C++</option>
                                <option value="json">JSON</option>
                                <option value="markdown">Markdown</option>
                            </select>
                        </div>
                        <button onclick="formatCode()" class="bg-editor-accent hover:bg-blue-600 text-white px-4 py-2 rounded transition-all duration-200 flex items-center space-x-2">
                            <i class="fas fa-magic"></i>
                            <span>Format</span>
                        </button>
                    </div>
                </div>

                <!-- Editor Content -->
                <div class="flex-1 bg-editor-bg relative">
                    <div class="mode-indicator" id="modeIndicator">TEXT MODE</div>
                    <div class="editor editor-content bg-editor-bg text-editor-text p-6 h-full overflow-y-auto focus:outline-none" 
                         contenteditable="true"><%- text.content %></div>
                </div>
            </div>
        </div>

        <!-- Status Bar -->
        <div class="bg-editor-sidebar border-t border-editor-border px-6 py-2 flex items-center justify-between text-sm text-editor-text-dim">
            <div class="flex items-center space-x-4">
                <span id="charCount">0 characters</span>
                <span id="wordCount">0 words</span>
                <span id="lineCount">1 line</span>
            </div>
            <div class="flex items-center space-x-4">
                <span>Last saved: <span id="lastSaved">Just now</span></span>
                <i class="fas fa-circle text-green-500 text-xs"></i>
            </div>
        </div>
    </div>

    <script>
        let currentMode = 'text';
        let editor = document.querySelector('.editor');
        let hasUnsavedChanges = false;
        let autoSaveTimer;

        // Mode switching
        function switchMode(mode) {
            currentMode = mode;
            const textToolbar = document.getElementById('textToolbar');
            const codeToolbar = document.getElementById('codeToolbar');
            const textBtn = document.getElementById('textModeBtn');
            const codeBtn = document.getElementById('codeModeBtn');
            const modeIndicator = document.getElementById('modeIndicator');

            if (mode === 'text') {
                textToolbar.classList.remove('hidden');
                codeToolbar.classList.add('hidden');
                textBtn.classList.add('active', 'bg-editor-accent', 'text-white');
                codeBtn.classList.remove('active', 'bg-editor-accent', 'text-white');
                modeIndicator.textContent = 'TEXT MODE';
                editor.style.fontFamily = 'inherit';
            } else {
                textToolbar.classList.add('hidden');
                codeToolbar.classList.remove('hidden');
                codeBtn.classList.add('active', 'bg-editor-accent', 'text-white');
                textBtn.classList.remove('active', 'bg-editor-accent', 'text-white');
                modeIndicator.textContent = 'CODE MODE';
                editor.style.fontFamily = 'Consolas, Monaco, Courier New, monospace';
            }
        }

        // Text formatting functions
        function formatText(command) {
            document.execCommand(command, false, null);
            markUnsaved();
            updateStats();
        }

        function changeFont(fontName) {
            document.execCommand('fontName', false, fontName);
            markUnsaved();
        }

        function changeFontSize(size) {
            document.execCommand('fontSize', false, size);
            markUnsaved();
        }

        function changeTextColor(color) {
            document.execCommand('foreColor', false, color);
            markUnsaved();
        }

        function insertList(type) {
            document.execCommand(type, false, null);
            markUnsaved();
            updateStats();
        }

        // Code functionality
        function insertCodeBlock() {
            const language = document.getElementById('codeLanguage').value;
            const codeBlock = `
                <div class="code-block" data-language="${language}" contenteditable="false">
                    <pre><code class="language-${language}" contenteditable="true">// Enter your ${language} code here...</code></pre>
                </div>
            `;
            
            document.execCommand('insertHTML', false, codeBlock);
            
            // Re-highlight syntax
            if (typeof Prism !== 'undefined') {
                setTimeout(() => Prism.highlightAll(), 100);
            }
            markUnsaved();
            updateStats();
        }

        function formatCode() {
            // Simple code formatting
            const selection = window.getSelection();
            if (selection.toString()) {
                const formatted = selection.toString()
                    .replace(/;/g, ';\n    ')
                    .replace(/{/g, ' {\n    ')
                    .replace(/}/g, '\n}');
                document.execCommand('insertText', false, formatted);
                markUnsaved();
            }
        }

        // Version history (placeholder)
        function showVersionHistory() {
            alert('Version history feature coming soon!');
        }

        // Save functionality
        function saveContent() {
            const title = document.querySelector(".files_title_input").value;
            const content = editor.innerHTML;
            const isPublic = document.getElementById("isPublic").checked;

            if (!title.trim()) {
                alert('Please enter a file name');
                return;
            }

            // Show saving indicator
            const saveBtn = document.querySelector('button[onclick="saveContent()"]');
            const saveStatus = document.getElementById('saveStatus');
            const originalText = saveBtn.innerHTML;
            
            saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Saving...';
            saveBtn.disabled = true;
            saveStatus.innerHTML = '<i class="fas fa-spinner fa-spin text-xs mr-2"></i><span>Saving changes...</span>';
            saveStatus.className = 'text-sm text-yellow-400 flex items-center space-x-2';

            fetch('/update/<%=text._id%>', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, content, isPublic }),
            })
            .then((response) => {
                if (response.ok) {
                    saveBtn.innerHTML = '<i class="fas fa-check mr-2"></i>Updated!';
                    saveStatus.innerHTML = '<i class="fas fa-circle text-green-500 text-xs mr-2"></i><span>All changes saved</span>';
                    saveStatus.className = 'text-sm text-green-400 flex items-center space-x-2';
                    hasUnsavedChanges = false;
                    updateLastSaved();
                    
                    setTimeout(() => {
                        saveBtn.innerHTML = '<i class="fas fa-save mr-2"></i>Update';
                        saveBtn.disabled = false;
                        saveStatus.className = 'text-sm text-editor-text-dim flex items-center space-x-2';
                    }, 2000);
                } else {
                    throw new Error('Update failed');
                }
            })
            .catch((error) => {
                console.error("Error:", error);
                saveBtn.innerHTML = '<i class="fas fa-exclamation-triangle mr-2"></i>Error';
                saveStatus.innerHTML = '<i class="fas fa-exclamation-triangle text-xs mr-2"></i><span>Save failed</span>';
                saveStatus.className = 'text-sm text-red-400 flex items-center space-x-2';
                
                setTimeout(() => {
                    saveBtn.innerHTML = originalText;
                    saveBtn.disabled = false;
                }, 3000);
            });
        }

        // Unsaved changes management
        function markUnsaved() {
            if (!hasUnsavedChanges) {
                hasUnsavedChanges = true;
                const saveStatus = document.getElementById('saveStatus');
                saveStatus.innerHTML = '<i class="fas fa-circle text-yellow-500 text-xs mr-2"></i><span>Unsaved changes</span>';
                saveStatus.className = 'text-sm text-yellow-400 flex items-center space-x-2';
            }
            startAutoSave();
        }

        function updateLastSaved() {
            const now = new Date();
            const timeString = now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            document.getElementById('lastSaved').textContent = timeString;
        }

        // Statistics update
        function updateStats() {
            const text = editor.textContent || editor.innerText || '';
            const words = text.trim().split(/\s+/).filter(word => word.length > 0);
            const lines = text.split('\n').length;
            
            document.getElementById('charCount').textContent = `${text.length} characters`;
            document.getElementById('wordCount').textContent = `${words.length} words`;
            document.getElementById('lineCount').textContent = `${lines} lines`;
        }

        // Auto-save functionality
        function startAutoSave() {
            clearTimeout(autoSaveTimer);
            autoSaveTimer = setTimeout(() => {
                if (hasUnsavedChanges) {
                    saveContent();
                }
            }, 30000); // Auto-save every 30 seconds
        }

        // Event listeners
        editor.addEventListener('input', function() {
            markUnsaved();
            updateStats();
        });

        editor.addEventListener('paste', function(e) {
            setTimeout(() => {
                markUnsaved();
                updateStats();
            }, 100);
        });

        // Prevent leaving with unsaved changes
        window.addEventListener('beforeunload', function(e) {
            if (hasUnsavedChanges) {
                e.preventDefault();
                e.returnValue = '';
            }
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            updateStats();
            updateLastSaved();
            
            // Set up change detection
            const titleInput = document.querySelector('.files_title_input');
            const publicCheckbox = document.getElementById('isPublic');
            
            titleInput.addEventListener('input', markUnsaved);
            publicCheckbox.addEventListener('change', markUnsaved);
            
            // Syntax highlighting
            if (typeof Prism !== 'undefined') {
                Prism.highlightAll();
            }
        });

        // Keyboard shortcuts
        document.addEventListener('keydown', function(e) {
            if (e.ctrlKey || e.metaKey) {
                switch(e.key) {
                    case 's':
                        e.preventDefault();
                        saveContent();
                        break;
                    case 'b':
                        e.preventDefault();
                        formatText('bold');
                        break;
                    case 'i':
                        e.preventDefault();
                        formatText('italic');
                        break;
                    case 'u':
                        e.preventDefault();
                        formatText('underline');
                        break;
                }
            }
        });
    </script>
    <!-- Set data in script-accessible way -->
<script>
  window.flashMessages = {
    success: '<%= typeof success !== "undefined" ? success : "" %>',
    error: '<%= typeof error !== "undefined" ? error : "" %>',
    warning: '<%= typeof warning !== "undefined" ? warning : "" %>'
  };
</script>

<!-- Clean JavaScript -->
<script>
  if (window.flashMessages.success) {
    Toastify({
      text: window.flashMessages.success,
      duration: 3000,
      style: { background: "linear-gradient(to right, #00b09b, #96c93d)" }
    }).showToast();
  }
  
  if (window.flashMessages.error) {
    Toastify({
      text: window.flashMessages.error,
      duration: 3000,
      style: { background: "linear-gradient(to right, #ff5f6d, #ffc371)" }
    }).showToast();
  }
  
  if (window.flashMessages.warning) {
    Toastify({
      text: window.flashMessages.warning,
      duration: 3000,
      style: { background: "linear-gradient(to right, #ffa726, #ffcc02)" }
    }).showToast();
  }
</script>

</body>
</html>
