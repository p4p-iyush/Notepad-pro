<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%=text.title%> - CodeNotes</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Add Toastify CSS & JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
<script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'editor-bg': '#0d1117',
              'editor-card': '#161b22',
              'editor-border': '#30363d',
              'editor-accent': '#58a6ff',
              'editor-text': '#f0f6fc',
              'editor-text-dim': '#7d8590',
              'reader-bg': '#0a0c10',
              'code-block': '#1c2128',
            },
            animation: {
              'slide-in': 'slideIn 0.3s ease-out',
              'fade-in': 'fadeIn 0.4s ease-out',
            },
            keyframes: {
              slideIn: {
                '0%': { transform: 'translateY(-20px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' }
              },
              fadeIn: {
                '0%': { opacity: '0' },
                '100%': { opacity: '1' }
              }
            }
          }
        }
      }
    </script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <style>
        .prose-content {
            line-height: 1.8;
        }
        .prose-content h1 { @apply text-3xl font-bold text-editor-text mb-6 mt-8; }
        .prose-content h2 { @apply text-2xl font-semibold text-editor-text mb-4 mt-6; }
        .prose-content h3 { @apply text-xl font-semibold text-editor-text mb-3 mt-5; }
        .prose-content p { @apply text-editor-text-dim mb-4 leading-relaxed; }
        .prose-content code { @apply bg-code-block text-editor-accent px-2 py-1 rounded text-sm; }
        .prose-content pre { @apply bg-code-block rounded-lg p-4 overflow-x-auto mb-6; }
        .prose-content blockquote { @apply border-l-4 border-editor-accent pl-4 italic text-editor-text-dim; }
        .prose-content ul { @apply list-disc list-inside text-editor-text-dim mb-4 space-y-2; }
        .prose-content ol { @apply list-decimal list-inside text-editor-text-dim mb-4 space-y-2; }
        .prose-content a { @apply text-editor-accent hover:underline; }
        
        /* Fullscreen styles */
        .fullscreen-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 9999;
            background: #0a0c10;
            overflow-y: auto;
            transform: translateY(100%);
            transition: transform 0.3s ease-out;
        }
        
        .fullscreen-modal.active {
            transform: translateY(0);
        }
        
        .fullscreen-content {
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            animation: fadeIn 0.5s ease-out 0.2s both;
        }
        
        /* Reading experience enhancements */
        .reading-progress {
            position: fixed;
            top: 0;
            left: 0;
            width: 0%;
            height: 3px;
            background: linear-gradient(to right, #58a6ff, #7c3aed);
            z-index: 1000;
            transition: width 0.1s ease;
        }
    </style>
</head>
<body class="bg-editor-bg text-editor-text font-mono min-h-screen">
    <!-- Reading Progress Bar -->
    <div class="reading-progress" id="readingProgress"></div>

    <!-- Navigation -->
    <nav class="bg-editor-card border-b border-editor-border sticky top-0 z-50 backdrop-blur-sm bg-opacity-95 animate-slide-in">
        <div class="max-w-6xl mx-auto px-6 py-4">
            <div class="flex items-center justify-between">
                <!-- Left Side -->
                <div class="flex items-center space-x-4">
                    <a href="/dashboard" class="flex items-center space-x-2 text-editor-text hover:text-editor-accent transition-colors duration-200">
                        <i class="fas fa-arrow-left"></i>
                        <span>Back to Dashboard</span>
                    </a>
                </div>

                <!-- Center - Title Preview -->
                <div class="hidden md:flex items-center space-x-2 text-editor-text-dim">
                    <i class="fas fa-file-alt"></i>
                    <span class="truncate max-w-xs"><%=text.title || 'Untitled Document'%></span>
                </div>

                <!-- Right Side -->
                <div class="flex items-center space-x-3">
                    <button onclick="toggleFullscreen()" 
                            class="bg-editor-accent hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-all duration-200 flex items-center space-x-2 shadow-lg hover:shadow-xl">
                        <i class="fas fa-expand-arrows-alt"></i>
                        <span>Fullscreen</span>
                    </button>
                    <a href="/edit/<%=text._id%>" 
                       class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg transition-all duration-200 flex items-center space-x-2">
                        <i class="fas fa-edit"></i>
                        <span>Edit</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-4xl mx-auto px-6 py-8 animate-fade-in">
        <!-- Document Header -->
        <header class="mb-8 pb-6 border-b border-editor-border">
            <h1 class="text-4xl font-bold text-editor-text mb-4 leading-tight">
                <i class="fas fa-file-code text-editor-accent mr-3"></i>
                <%=text.title || 'Untitled Document'%>
            </h1>
            <div class="flex items-center space-x-6 text-sm text-editor-text-dim">
                <div class="flex items-center space-x-2">
                    <i class="fas fa-calendar-alt"></i>
                    <span><%=text.Currentdate ? new Date(text.Currentdate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : 'No date'%></span>
                </div>
                <div class="flex items-center space-x-2">
                    <i class="fas fa-user-circle"></i>
                    <span>Created by you</span>
                </div>
                <% if (text.isPublic) { %>
                    <span class="bg-green-600 text-white px-3 py-1 rounded-full text-xs flex items-center">
                        <i class="fas fa-globe mr-1"></i>
                        Public
                    </span>
                <% } else { %>
                    <span class="bg-gray-600 text-white px-3 py-1 rounded-full text-xs flex items-center">
                        <i class="fas fa-lock mr-1"></i>
                        Private
                    </span>
                <% } %>
            </div>
        </header>

        <!-- Document Content -->
        <article class="prose-content" id="documentContent">
            <div class="bg-editor-card border border-editor-border rounded-xl p-8 shadow-xl">
                <div class="text-editor-text leading-relaxed" style="font-size: 16px; line-height: 1.8;">
                    <%-text.content || '<p class="text-editor-text-dim italic">No content available</p>'%>
                </div>
            </div>
        </article>

        <!-- Reading Stats -->
        <div class="mt-8 bg-editor-card border border-editor-border rounded-lg p-6">
            <h3 class="text-lg font-semibold text-editor-text mb-4 flex items-center">
                <i class="fas fa-chart-line mr-2 text-editor-accent"></i>
                Reading Stats
            </h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
                <div class="bg-editor-bg rounded-lg p-4">
                    <div class="text-2xl font-bold text-editor-accent" id="wordCount">0</div>
                    <div class="text-sm text-editor-text-dim">Words</div>
                </div>
                <div class="bg-editor-bg rounded-lg p-4">
                    <div class="text-2xl font-bold text-editor-accent" id="charCount">0</div>
                    <div class="text-sm text-editor-text-dim">Characters</div>
                </div>
                <div class="bg-editor-bg rounded-lg p-4">
                    <div class="text-2xl font-bold text-editor-accent" id="readTime">0</div>
                    <div class="text-sm text-editor-text-dim">Min Read</div>
                </div>
                <div class="bg-editor-bg rounded-lg p-4">
                    <div class="text-2xl font-bold text-editor-accent" id="paragraphs">0</div>
                    <div class="text-sm text-editor-text-dim">Paragraphs</div>
                </div>
            </div>
        </div>
    </main>

    <!-- Fullscreen Modal -->
    <div id="fullscreenModal" class="fullscreen-modal">
        <div class="fullscreen-content">
            <!-- Fullscreen Header -->
            <div class="flex items-center justify-between mb-8 pb-4 border-b border-editor-border">
                <h2 class="text-2xl font-bold text-editor-text flex items-center">
                    <i class="fas fa-book-open text-editor-accent mr-3"></i>
                    Reading Mode
                </h2>
                <button onclick="toggleFullscreen()" 
                        class="text-editor-text-dim hover:text-editor-text transition-colors duration-200 text-2xl">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <!-- Fullscreen Content -->
            <article class="prose-content">
                <h1 class="text-4xl font-bold text-editor-text mb-6 text-center">
                    <%=text.title || 'Untitled Document'%>
                </h1>
                <div class="text-center mb-8 pb-6 border-b border-editor-border">
                    <div class="text-editor-text-dim">
                        <%=text.Currentdate ? new Date(text.Currentdate).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) : 'No date'%>
                    </div>
                </div>
                <div class="text-editor-text text-lg leading-relaxed max-w-none" style="line-height: 2;">
                    <%-text.content || '<p class="text-editor-text-dim italic text-center">No content available</p>'%>
                </div>
            </article>
        </div>
    </div>

    <script>
        // Fullscreen toggle functionality
        function toggleFullscreen() {
            const modal = document.getElementById('fullscreenModal');
            modal.classList.toggle('active');
            
            if (modal.classList.contains('active')) {
                document.body.style.overflow = 'hidden';
                // Focus trap for accessibility
                modal.focus();
            } else {
                document.body.style.overflow = 'auto';
            }
        }

        // ESC key to exit fullscreen
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                const modal = document.getElementById('fullscreenModal');
                if (modal.classList.contains('active')) {
                    toggleFullscreen();
                }
            }
        });

        // Reading progress bar
        function updateReadingProgress() {
            const content = document.getElementById('documentContent');
            const progressBar = document.getElementById('readingProgress');
            
            const contentHeight = content.offsetHeight;
            const windowHeight = window.innerHeight;
            const scrolled = window.pageYOffset;
            const progress = (scrolled / (contentHeight - windowHeight)) * 100;
            
            progressBar.style.width = Math.min(100, Math.max(0, progress)) + '%';
        }

        window.addEventListener('scroll', updateReadingProgress);
        window.addEventListener('resize', updateReadingProgress);

        // Calculate reading stats
        function calculateStats() {
            const content = document.getElementById('documentContent');
            const text = content.textContent || content.innerText || '';
            
            // Remove extra whitespace and split into words
            const words = text.trim().split(/\s+/).filter(word => word.length > 0);
            const wordCount = words.length;
            const charCount = text.length;
            const readTime = Math.ceil(wordCount / 200); // Average reading speed
            const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim().length > 0).length;
            
            document.getElementById('wordCount').textContent = wordCount;
            document.getElementById('charCount').textContent = charCount;
            document.getElementById('readTime').textContent = readTime;
            document.getElementById('paragraphs').textContent = paragraphs;
        }

        // Initialize when page loads
        document.addEventListener('DOMContentLoaded', function() {
            calculateStats();
            updateReadingProgress();
            
            // Highlight code blocks
            if (typeof Prism !== 'undefined') {
                Prism.highlightAll();
            }
        });

        // Smooth scroll for better reading experience
        document.documentElement.style.scrollBehavior = 'smooth';
    </script>
    <!-- Set data in script-accessible way -->
<script>
  window.flashMessages = {
    success: '<%= typeof success !== "undefined" ? success : "" %>',
    error: '<%= typeof error !== "undefined" ? error : "" %>',
    warning: '<%= typeof warning !== "undefined" ? warning : "" %>'
  };
</script>

<!-- Clean JavaScript -->
<script>
  if (window.flashMessages.success) {
    Toastify({
      text: window.flashMessages.success,
      duration: 3000,
      style: { background: "linear-gradient(to right, #00b09b, #96c93d)" }
    }).showToast();
  }
  
  if (window.flashMessages.error) {
    Toastify({
      text: window.flashMessages.error,
      duration: 3000,
      style: { background: "linear-gradient(to right, #ff5f6d, #ffc371)" }
    }).showToast();
  }
  
  if (window.flashMessages.warning) {
    Toastify({
      text: window.flashMessages.warning,
      duration: 3000,
      style: { background: "linear-gradient(to right, #ffa726, #ffcc02)" }
    }).showToast();
  }
</script>

</body>
</html>
